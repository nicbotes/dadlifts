# Copy to .env and fill in values
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

DADLIFT_API_KEY=your_secret_key_here
PORT=3001

# DB path — defaults to server/dadlift.db if not set
# DB_PATH=/var/data/dadlift.db

# Restrict CORS to your frontend domain in production
# FRONTEND_ORIGIN=https://dadlift.yourdomain.com
